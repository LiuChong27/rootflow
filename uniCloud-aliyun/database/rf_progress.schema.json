{
  "bsonType": "object",
  "description": "RootFlow spaced-repetition progress by user and word",
  "required": ["openid", "wordId", "status", "stage", "updatedAt", "createdAt"],
  "permission": {
    "read": false,
    "create": false,
    "update": false,
    "delete": false,
    "count": false
  },
  "properties": {
    "_id": {
      "description": "Document ID generated by uniCloud"
    },
    "openid": {
      "bsonType": "string",
      "description": "WeChat mini program openid",
      "trim": "both",
      "label": "OpenID"
    },
    "wordId": {
      "bsonType": "string",
      "description": "Normalized word identifier",
      "trim": "both",
      "label": "Word ID"
    },
    "rootId": {
      "bsonType": "string",
      "description": "Normalized root identifier",
      "trim": "both",
      "defaultValue": "",
      "label": "Root ID"
    },
    "status": {
      "bsonType": "string",
      "description": "Current learning state",
      "enum": [
        {
          "text": "New",
          "value": "new"
        },
        {
          "text": "Learning",
          "value": "learning"
        },
        {
          "text": "Review",
          "value": "review"
        },
        {
          "text": "Mastered",
          "value": "mastered"
        }
      ],
      "label": "Status"
    },
    "stage": {
      "bsonType": "int",
      "description": "Review stage from 0 to 4",
      "minimum": 0,
      "maximum": 4,
      "label": "Stage"
    },
    "introducedAt": {
      "bsonType": "long",
      "description": "First introduced timestamp in milliseconds",
      "label": "Introduced At"
    },
    "lastReviewedAt": {
      "bsonType": "long",
      "description": "Last review timestamp in milliseconds",
      "label": "Last Reviewed At"
    },
    "nextReviewAt": {
      "bsonType": "long",
      "description": "Next scheduled review timestamp in milliseconds",
      "label": "Next Review At"
    },
    "updatedAt": {
      "bsonType": "long",
      "description": "Last update timestamp in milliseconds",
      "label": "Updated At"
    },
    "createdAt": {
      "bsonType": "long",
      "description": "Create timestamp in milliseconds",
      "label": "Created At"
    },
    "lapseCount": {
      "bsonType": "int",
      "description": "How many times the word lapsed",
      "minimum": 0,
      "defaultValue": 0,
      "label": "Lapse Count"
    },
    "correctCount": {
      "bsonType": "int",
      "description": "How many successful reviews were recorded",
      "minimum": 0,
      "defaultValue": 0,
      "label": "Correct Count"
    }
  }
}
