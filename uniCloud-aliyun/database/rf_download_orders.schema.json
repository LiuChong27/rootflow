{
  "bsonType": "object",
  "description": "RootFlow purchase orders for download products",
  "required": ["openid", "orderNo", "sku"],
  "permission": {
    "read": false,
    "create": false,
    "update": false,
    "delete": false,
    "count": false
  },
  "properties": {
    "_id": {
      "description": "Document ID generated by uniCloud"
    },
    "openid": {
      "bsonType": "string",
      "description": "WeChat mini program openid",
      "trim": "both",
      "label": "OpenID"
    },
    "orderNo": {
      "bsonType": "string",
      "description": "Business order number",
      "trim": "both",
      "label": "Order No"
    },
    "sku": {
      "bsonType": "string",
      "description": "Purchased sku",
      "trim": "both",
      "label": "SKU"
    },
    "title": {
      "bsonType": "string",
      "description": "Display title for the order",
      "trim": "both",
      "defaultValue": "",
      "label": "Title"
    },
    "amountFen": {
      "bsonType": "long",
      "description": "Order amount in fen",
      "defaultValue": 0,
      "label": "Amount Fen"
    },
    "benefitType": {
      "bsonType": "string",
      "description": "Entitlement benefit type",
      "trim": "both",
      "defaultValue": "",
      "label": "Benefit Type"
    },
    "creditDelta": {
      "bsonType": "long",
      "description": "Credit amount to grant for credit packs",
      "defaultValue": 0,
      "label": "Credit Delta"
    },
    "isLifetimeMember": {
      "bsonType": "bool",
      "description": "Whether this order grants lifetime access",
      "defaultValue": false,
      "label": "Lifetime Member"
    },
    "status": {
      "bsonType": "string",
      "description": "Order lifecycle status",
      "trim": "both",
      "defaultValue": "created",
      "label": "Status"
    },
    "paymentMode": {
      "bsonType": "string",
      "description": "Configured payment adapter mode",
      "trim": "both",
      "defaultValue": "disabled",
      "label": "Payment Mode"
    },
    "source": {
      "bsonType": "string",
      "description": "Purchase source such as downloads",
      "trim": "both",
      "defaultValue": "",
      "label": "Source"
    },
    "clientPlatform": {
      "bsonType": "string",
      "description": "Client platform string",
      "trim": "both",
      "defaultValue": "",
      "label": "Client Platform"
    },
    "paymentPayload": {
      "bsonType": "object",
      "description": "Serialized payment payload metadata",
      "defaultValue": {},
      "label": "Payment Payload"
    },
    "fulfillmentStatus": {
      "bsonType": "string",
      "description": "Entitlement fulfillment guard status",
      "trim": "both",
      "defaultValue": "pending",
      "label": "Fulfillment Status"
    },
    "paidAt": {
      "bsonType": "long",
      "description": "Paid timestamp in milliseconds",
      "defaultValue": 0,
      "label": "Paid At"
    },
    "fulfilledAt": {
      "bsonType": "long",
      "description": "Entitlement fulfilled timestamp in milliseconds",
      "defaultValue": 0,
      "label": "Fulfilled At"
    },
    "createdAt": {
      "bsonType": "long",
      "description": "Create timestamp in milliseconds",
      "label": "Created At"
    },
    "updatedAt": {
      "bsonType": "long",
      "description": "Last update timestamp in milliseconds",
      "label": "Updated At"
    }
  }
}
