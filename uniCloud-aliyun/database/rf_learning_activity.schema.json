{
  "bsonType": "object",
  "description": "RootFlow daily activity markers by user",
  "required": ["openid", "dateKey", "createdAt"],
  "permission": {
    "read": false,
    "create": false,
    "update": false,
    "delete": false,
    "count": false
  },
  "properties": {
    "_id": {
      "description": "Document ID generated by uniCloud"
    },
    "openid": {
      "bsonType": "string",
      "description": "WeChat mini program openid",
      "trim": "both",
      "label": "OpenID"
    },
    "dateKey": {
      "bsonType": "string",
      "description": "Activity date in YYYY-MM-DD format",
      "trim": "both",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
      "label": "Date Key"
    },
    "createdAt": {
      "bsonType": "long",
      "description": "Create timestamp in milliseconds",
      "label": "Created At"
    }
  }
}
