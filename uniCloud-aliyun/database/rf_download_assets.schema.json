{
  "bsonType": "object",
  "description": "RootFlow downloadable PDF asset catalog",
  "required": ["assetKey", "letter"],
  "permission": {
    "read": false,
    "create": false,
    "update": false,
    "delete": false,
    "count": false
  },
  "properties": {
    "_id": {
      "description": "Document ID generated by uniCloud"
    },
    "assetKey": {
      "bsonType": "string",
      "description": "Stable asset identifier such as pdf-a",
      "trim": "both",
      "label": "Asset Key"
    },
    "letter": {
      "bsonType": "string",
      "description": "Alphabet letter a-z",
      "trim": "both",
      "label": "Letter"
    },
    "title": {
      "bsonType": "string",
      "description": "Display title such as A.pdf",
      "trim": "both",
      "defaultValue": "",
      "label": "Title"
    },
    "label": {
      "bsonType": "string",
      "description": "Optional short label shown in the client",
      "trim": "both",
      "defaultValue": "",
      "label": "Label"
    },
    "coveredLetters": {
      "bsonType": "array",
      "description": "Letters covered by this asset, used for grouped PDFs such as U&W",
      "defaultValue": [],
      "label": "Covered Letters"
    },
    "version": {
      "bsonType": "string",
      "description": "Version string for local cache comparison",
      "trim": "both",
      "defaultValue": "",
      "label": "Version"
    },
    "size": {
      "bsonType": "long",
      "description": "File size in bytes",
      "defaultValue": 0,
      "label": "Size"
    },
    "fileType": {
      "bsonType": "string",
      "description": "File type, usually pdf",
      "trim": "both",
      "defaultValue": "pdf",
      "label": "File Type"
    },
    "fileId": {
      "bsonType": "string",
      "description": "uniCloud storage file id",
      "trim": "both",
      "defaultValue": "",
      "label": "File ID"
    },
    "cloudPath": {
      "bsonType": "string",
      "description": "Optional uniCloud storage path fallback such as rootflow/pdfs/v2/短语A.pdf",
      "trim": "both",
      "defaultValue": "",
      "label": "Cloud Path"
    },
    "status": {
      "bsonType": "string",
      "description": "Catalog status such as active or draft",
      "trim": "both",
      "defaultValue": "active",
      "label": "Status"
    },
    "createdAt": {
      "bsonType": "long",
      "description": "Create timestamp in milliseconds",
      "label": "Created At"
    },
    "updatedAt": {
      "bsonType": "long",
      "description": "Last update timestamp in milliseconds",
      "label": "Updated At"
    }
  }
}
