{
  "bsonType": "object",
  "description": "RootFlow user profile and sync metadata",
  "required": ["openid"],
  "permission": {
    "read": false,
    "create": false,
    "update": false,
    "delete": false,
    "count": false
  },
  "properties": {
    "_id": {
      "description": "Document ID generated by uniCloud"
    },
    "openid": {
      "bsonType": "string",
      "description": "WeChat mini program openid",
      "trim": "both",
      "label": "OpenID"
    },
    "nickName": {
      "bsonType": "string",
      "description": "WeChat profile nickname",
      "trim": "both",
      "defaultValue": "",
      "label": "Nickname"
    },
    "avatarUrl": {
      "bsonType": "string",
      "description": "WeChat profile avatar URL",
      "trim": "both",
      "defaultValue": "",
      "label": "Avatar URL"
    },
    "createdAt": {
      "bsonType": "long",
      "description": "Create timestamp in milliseconds",
      "label": "Created At"
    },
    "updatedAt": {
      "bsonType": "long",
      "description": "Last update timestamp in milliseconds",
      "label": "Updated At"
    },
    "lastLoginAt": {
      "bsonType": "long",
      "description": "Last login timestamp in milliseconds",
      "label": "Last Login At"
    },
    "lastSyncAt": {
      "bsonType": "long",
      "description": "Last sync timestamp in milliseconds",
      "label": "Last Sync At"
    }
  }
}
