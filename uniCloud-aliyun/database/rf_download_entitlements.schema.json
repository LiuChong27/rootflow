{
  "bsonType": "object",
  "description": "RootFlow download membership and credit balances",
  "required": ["openid"],
  "permission": {
    "read": false,
    "create": false,
    "update": false,
    "delete": false,
    "count": false
  },
  "properties": {
    "_id": {
      "description": "Document ID generated by uniCloud"
    },
    "openid": {
      "bsonType": "string",
      "description": "WeChat mini program openid",
      "trim": "both",
      "label": "OpenID"
    },
    "isLifetimeMember": {
      "bsonType": "bool",
      "description": "Whether the user has unlimited access",
      "defaultValue": false,
      "label": "Lifetime Member"
    },
    "lifetimeActivatedAt": {
      "bsonType": "long",
      "description": "Timestamp when lifetime membership became active",
      "defaultValue": 0,
      "label": "Lifetime Activated At"
    },
    "creditBalance": {
      "bsonType": "long",
      "description": "Remaining download credits",
      "defaultValue": 0,
      "label": "Credit Balance"
    },
    "totalPurchasedCredits": {
      "bsonType": "long",
      "description": "Total purchased credits over time",
      "defaultValue": 0,
      "label": "Total Purchased Credits"
    },
    "totalConsumedCredits": {
      "bsonType": "long",
      "description": "Total consumed credits over time",
      "defaultValue": 0,
      "label": "Total Consumed Credits"
    },
    "lastOrderNo": {
      "bsonType": "string",
      "description": "Most recent order number that changed entitlement",
      "trim": "both",
      "defaultValue": "",
      "label": "Last Order No"
    },
    "lastTicketId": {
      "bsonType": "string",
      "description": "Most recent download ticket that consumed credits",
      "trim": "both",
      "defaultValue": "",
      "label": "Last Ticket ID"
    },
    "createdAt": {
      "bsonType": "long",
      "description": "Create timestamp in milliseconds",
      "label": "Created At"
    },
    "updatedAt": {
      "bsonType": "long",
      "description": "Last update timestamp in milliseconds",
      "label": "Updated At"
    }
  }
}
