{
  "bsonType": "object",
  "description": "RootFlow temporary download tickets per asset request",
  "required": ["ticketId", "openid", "assetKey"],
  "permission": {
    "read": false,
    "create": false,
    "update": false,
    "delete": false,
    "count": false
  },
  "properties": {
    "_id": {
      "description": "Document ID generated by uniCloud"
    },
    "ticketId": {
      "bsonType": "string",
      "description": "Business ticket identifier",
      "trim": "both",
      "label": "Ticket ID"
    },
    "openid": {
      "bsonType": "string",
      "description": "WeChat mini program openid",
      "trim": "both",
      "label": "OpenID"
    },
    "assetKey": {
      "bsonType": "string",
      "description": "Stable asset identifier such as pdf-a",
      "trim": "both",
      "label": "Asset Key"
    },
    "letter": {
      "bsonType": "string",
      "description": "Alphabet letter a-z",
      "trim": "both",
      "defaultValue": "",
      "label": "Letter"
    },
    "title": {
      "bsonType": "string",
      "description": "Display title",
      "trim": "both",
      "defaultValue": "",
      "label": "Title"
    },
    "version": {
      "bsonType": "string",
      "description": "Asset version at ticket creation time",
      "trim": "both",
      "defaultValue": "",
      "label": "Version"
    },
    "fileType": {
      "bsonType": "string",
      "description": "File type, usually pdf",
      "trim": "both",
      "defaultValue": "pdf",
      "label": "File Type"
    },
    "fileId": {
      "bsonType": "string",
      "description": "uniCloud storage file id",
      "trim": "both",
      "defaultValue": "",
      "label": "File ID"
    },
    "cloudPath": {
      "bsonType": "string",
      "description": "Optional uniCloud storage path fallback",
      "trim": "both",
      "defaultValue": "",
      "label": "Cloud Path"
    },
    "status": {
      "bsonType": "string",
      "description": "Ticket status such as created, consuming, consumed, expired",
      "trim": "both",
      "defaultValue": "created",
      "label": "Status"
    },
    "expiresAt": {
      "bsonType": "long",
      "description": "Expiration timestamp in milliseconds",
      "defaultValue": 0,
      "label": "Expires At"
    },
    "confirmedAt": {
      "bsonType": "long",
      "description": "Success confirmation timestamp in milliseconds",
      "defaultValue": 0,
      "label": "Confirmed At"
    },
    "consumedCredit": {
      "bsonType": "long",
      "description": "Credits consumed by this ticket",
      "defaultValue": 0,
      "label": "Consumed Credit"
    },
    "createdAt": {
      "bsonType": "long",
      "description": "Create timestamp in milliseconds",
      "label": "Created At"
    },
    "updatedAt": {
      "bsonType": "long",
      "description": "Last update timestamp in milliseconds",
      "label": "Updated At"
    }
  }
}
