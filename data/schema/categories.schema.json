{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rootflow.dev/schema/categories.schema.json",
  "title": "CategoryIndex",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "categories"
  ],
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "updatedAt": {
      "type": "string"
    },
    "categories": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "label",
          "wordIds",
          "rootIds"
        ],
        "properties": {
          "label": {
            "type": "string"
          },
          "wordIds": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^[a-z0-9-]+$"
            }
          },
          "rootIds": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^[a-z0-9-]+$"
            }
          }
        }
      }
    }
  }
}

